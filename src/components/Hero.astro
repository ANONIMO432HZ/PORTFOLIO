---
import "../styles/Hero.css";
---

<div class="contenido">
    <!-- tsParticles Container -->
    <div id="tsparticles" class="particles-2-css"></div>

    <section class="inicio" id="inicio">
        <div class="titulo">
            <p data-aos="fade-up" data-aos-delay="600" data-i18n="greeting">Hola</p>
            <h1 data-aos="fade-up" data-aos-delay="800" data-i18n="name">Soy Nahuel Carrizo</h1>
            <p data-aos="fade-up" data-aos-delay="1000" data-i18n="rol">Full-stack developer</p>

            <div class="redes-sociales">
                <a href="https://github.com/ANONIMO432HZ" target="_blank" rel="noopener noreferrer" data-aos="fade-up" data-aos-delay="1200"><i class="fab fa-github"></i></a>
                <a href="mailto:usuario432hz@gmail.com" target="_blank" rel="noopener noreferrer" data-aos="fade-up" data-aos-delay="1400"><i class="fas fa-envelope"></i></a>
            </div>
            
            <div class="wrapper">
                <a class="button" href="https://github.com/ANONIMO432HZ" target="_blank" rel="noopener noreferrer" data-aos="fade-up" data-aos-delay="1200">
                    <div class="icon">
                        <i class="fab fa-github"></i>
                    </div>
                    <span>Github</span>
                </a>
                <a class="button" href="mailto:usuario432hz@gmail.com" target="_blank" rel="noopener noreferrer" data-aos="fade-up" data-aos-delay="1400">
                    <div class="icon">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <span>Email</span>
                </a>
            </div>

            <a href="#sobre-mi">
                <div class="scroll-down"></div>
            </a>
        </div>
    </section>
</div>

<script>
    function initHeaderParticles() {
        // @ts-ignore
        if (typeof tsParticles !== 'undefined') {
            // @ts-ignore
            tsParticles.load("tsparticles", {
                background: {
                    position: "50% 50%",
                    repeat: "no-repeat",
                    size: "cover",
                    color: "transparent"
                },
                fullScreen: {
                    enable: false
                },
                particles: {
                    color: {
                        value: "#ffffff",
                    },
                    links: {
                        color: {
                            value: "#000",
                        },
                        distance: 150,
                        enable: false,
                        opacity: 0.4,
                    },
                    move: {
                        enable: true,
                        speed: 2,
                        direction: "none",
                        random: false,
                        straight: false,
                        outModes: {
                            bottom: "out",
                            left: "out",
                            right: "out",
                            top: "out",
                        },
                    },
                    number: {
                        value: 20,
                    },
                    opacity: {
                        random: {
                            enable: true,
                        },
                        value: {
                            min: 0.1,
                            max: 0.8,
                        },
                    },
                    shape: {
                        options: {
                            image: [
                                { src: "/img/skills/html5.svg", width: 20, height: 20 },
                                { src: "/img/skills/css3.svg", width: 20, height: 20 },
                                { src: "/img/skills/javascript.svg", width: 20, height: 20 },
                                { src: "/img/skills/jquery.svg", width: 20, height: 20 },
                                { src: "/img/skills/react.svg", width: 20, height: 20 },
                                { src: "/img/skills/typescript.svg", width: 20, height: 20 },
                                { src: "/img/skills/nodejs.svg", width: 20, height: 20 },
                                { src: "/img/skills/mongodb.svg", width: 20, height: 20 },
                                { src: "/img/skills/php.svg", width: 20, height: 20 },
                                { src: "/img/skills/sass.svg", width: 20, height: 20 },
                                { src: "/img/skills/bootstrap.svg", width: 20, height: 20 },
                                { src: "/img/skills/tailwindcss.svg", width: 20, height: 20 },
                                { src: "/img/skills/postgresql.svg", width: 20, height: 20 }
                            ]
                        },
                        type: "image",
                    },
                    size: {
                        value: 30,
                    }
                },
                retina_detect: true
            });
        }
    }

    document.addEventListener('DOMContentLoaded', initHeaderParticles);
</script>
