                    <p data-i18n="projects-info-5-p2">Una página de aterrizaje moderna y completamente responsiva diseñada para promocionar servicios, tarifas y reservas de una barbería profesional.</p>
                    <div class="eins-modal-text-2">
                        <span data-i18n="projects-link">Enlace:</span> <a href="https://barbershop-huanta.vercel.app/" target="_blank">https://barbershop-huanta.vercel.app/</a>
                    </div>
                    <div class="eins-modal-text-3">
                        <span data-i18n="projects-tec">Tecnologías Utilizadas:</span>
                        <div class="eins-modal-tec">
                            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg" alt="Astro" />
                            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg" alt="TypeScript" />
                            <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/javascript/javascript-plain.svg" alt="JavaScript" />
                            <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/css3/css3-original.svg" alt="CSS3" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Initialize Swiper and Modal Handlers
    // @ts-ignore
    if (typeof Swiper !== 'undefined') {
        // @ts-ignore
        new Swiper(".mySwiper", {
            spaceBetween: 30,
            loop: true,
            grabCursor: true,
            centeredSlides: true,
            autoplay: {
                delay: 2500,
                disableOnInteraction: false,
                pauseOnMouseEnter: true, // Pauses autoplay when mouse hovers over the slider
            },
            pagination: {
                el: ".swiper-pagination",
                clickable: true,
            },
            navigation: {
                nextEl: ".swiper-button-next",
                prevEl: ".swiper-button-prev",
            },
            breakpoints: {
                0: {
                    slidesPerView: 1,
                },
                768: {
                    slidesPerView: 2,
                },
                1024: {
                    slidesPerView: 3,
                },
            },
        });
    }

    // Global Event Delegation for Modals to handle dynamically generated Swiper clones
    document.addEventListener('click', (e) => {
        const target = e.target;
        if (!target) return;
        
        // Check if user clicked on a project image trigger
        const trigger = target.closest('.project-trigger');
        if (trigger) {
            e.preventDefault();
            const modalId = trigger.getAttribute('data-modal');
            if (modalId) {
                const modal = document.getElementById(modalId);
                if (modal) {
                    modal.classList.add('active');
                }
            }
            return;
        }

        // Check if user clicked on the close button
        const closeBtn = target.closest('.boton-cerrar');
        if (closeBtn) {
            const modal = closeBtn.closest('.overlay');
            if (modal) {
                modal.classList.remove('active');
            }
            return;
        }

        // Check if user clicked on the backdrop overlay
        if (target.classList.contains('overlay')) {
            target.classList.remove('active');
            return;
        }
    });
</script>
