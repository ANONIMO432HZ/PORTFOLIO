---
import "../styles/App.css";
---

<div id="particles" class="particles-css"></div>

<script>
    function initBackgroundParticles() {
        // @ts-ignore
        if (typeof tsParticles !== 'undefined') {
            // @ts-ignore
            tsParticles.load("particles", {
                particles: {
                    number: {
                        value: 6,
                        density: {
                            enable: true,
                            value_area: 800
                        }
                    },
                    color: {
                        value: "#1b1e34"
                    },
                    shape: {
                        type: "polygon",
                        stroke: {
                            width: 0,
                            color: "#000"
                        },
                        polygon: {
                            sides: 6
                        }
                    },
                    opacity: {
                        value: 0.3,
                        random: true,
                        anim: {
                            enable: false,
                            speed: 1,
                            opacity_min: 0.1,
                            sync: false
                        }
                    },
                    size: {
                        value: 160,
                        random: false,
                        anim: {
                            enable: true,
                            speed: 10,
                            size_min: 40,
                            sync: false
                        }
                    },
                    line_linked: {
                        enable: false
                    },
                    move: {
                        enable: true,
                        speed: 8,
                        direction: "none",
                        random: false,
                        straight: false,
                        out_mode: "out",
                        bounce: false
                    }
                },
                interactivity: {
                    detect_on: "canvas",
                    events: {
                        resize: true
                    }
                },
                retina_detect: true
            });
        }
    }

    document.addEventListener('DOMContentLoaded', initBackgroundParticles);
</script>
