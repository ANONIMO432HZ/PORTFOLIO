---
import "../styles/App.css";
import "../styles/Header.css";

interface Props {
	isHomePage?: boolean;
}

const {
	isHomePage = Astro.url.pathname === "/" ||
		Astro.url.pathname === "/index.html",
} = Astro.props;
---

<header class="site-header">
    <div id="menu-btn" class="fas fa-bars"></div>

    <a class="logo" href="/">
        <p>=(<span>ANONIMO432HZ</span>)=></p>
    </a>

    <nav class="navbar">
        {isHomePage ? (
            <>
                <a href="#inicio" data-i18n="home">Inicio</a>
                <a href="#sobre-mi" data-i18n="about">Sobre mi</a>
                <a href="#servicios" data-i18n="services">Servicios</a>
                <a href="#proyectos" data-i18n="projects">Proyectos</a>
                <a href="#contactos" data-i18n="contact">Contactos</a>
            </>
        ) : (
            <>
                <a href="/" data-i18n="home">Inicio</a>
                <a href="/about" data-i18n="about">Sobre mi</a>
                <a href="/service" data-i18n="services">Servicios</a>
                <a href="/project" data-i18n="projects">Proyectos</a>
            </>
        )}
    </nav>

    <div class="header-actions">
        <!-- Unified Language Dropdown Select -->
        <div class="lang-selector-container">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-languages-icon lucide-languages"><path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/></svg>
            <select id="language-select" aria-label="Select Language">
                <option value="es-ES">ES</option>
                <option value="en-US">EN</option>
            </select>
        </div>

        <!-- Theme Toggle Button -->
        <button id="theme-toggle" class="theme-btn" aria-label="Toggle Theme">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-moon-icon lucide-moon"><path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"/></svg>
        </button>

        <!-- GitHub Icon Link -->
        <a href="https://github.com/ANONIMO432HZ" target="_blank" rel="noopener noreferrer" class="github-header-link" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="github-icon"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
    </div>
</header>

<script>
    // Responsive mobile menu toggle
    const menuBtn = document.querySelector('#menu-btn');
    const navbar = document.querySelector('.navbar');
    const header = document.querySelector('.site-header');

    menuBtn?.addEventListener('click', () => {
        navbar?.classList.toggle('activar');
    });

    // Handle background opacity on scroll
    window.addEventListener('scroll', () => {
        if (window.scrollY > 0) {
            header?.classList.add('activar');
        } else {
            header?.classList.remove('activar');
        }
        navbar?.classList.remove('activar');
    });

    // Language selector select change handler
    const langSelect = document.getElementById('language-select') as HTMLSelectElement;
    langSelect?.addEventListener('change', (e) => {
        const target = e.target as HTMLSelectElement;
        // @ts-ignore
        if (window.setLanguage) {
            // @ts-ignore
            window.setLanguage(target.value);
        }
    });

    // Sync select value on custom language change event
    window.addEventListener('langChanged', (e: any) => {
        if (langSelect) {
            langSelect.value = e.detail;
        }
    });

    // Sync initial language select value on load
    const savedLang = localStorage.getItem('lang') || 'es-ES';
    if (langSelect) {
        langSelect.value = savedLang;
    }

    // Theme toggle logic (Sun/Moon icon buttons)
    const themeBtn = document.getElementById("theme-toggle");
    const lightTheme = "light";
    const darkTheme = "dark";

    const sunSVG = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sun-icon lucide-sun"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>`;
    const moonSVG = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-moon-icon lucide-moon"><path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"/></svg>`;

    function updateThemeIcon() {
        const theme = localStorage.getItem("theme") || darkTheme;
        if (themeBtn) {
            themeBtn.innerHTML = theme === darkTheme ? moonSVG : sunSVG;
        }
    }

    function switchTheme() {
        const body = document.body;
        const html = document.documentElement;
        let theme = localStorage.getItem("theme") || darkTheme;

        if (theme === darkTheme) {
            body.classList.remove(darkTheme);
            body.classList.add(lightTheme);
            html.classList.remove(darkTheme);
            html.classList.add(lightTheme);
            localStorage.setItem("theme", lightTheme);
        } else {
            body.classList.remove(lightTheme);
            body.classList.add(darkTheme);
            html.classList.remove(lightTheme);
            html.classList.add(darkTheme);
            localStorage.setItem("theme", darkTheme);
        }
        updateThemeIcon();
    }

    themeBtn?.addEventListener("click", switchTheme);

    // Initialize icon on load
    updateThemeIcon();
</script>
