---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import Footer from '../components/Footer.astro';
import '../../src/styles/ServicesPage.css';
---

<Layout title="Servicios =(Nahuel61920)=>">
    <Header isHomePage={false} />
    
    <ParticleBackground />

    <main class="service-page">
        <!-- Services Section -->
        <section class="servicios" id="servicios">
            <h2 class="heading" data-i18n="services">Servicios</h2>
            <div class="row">
                <div class="columns" data-aos="fade-up" data-aos-delay="200">
                    <i class="fas fa-drafting-compass"></i>
                    <h3 data-i18n="design">Diseño UX/UI</h3>
                    <p data-i18n="design-info">Diseño de interfaz atractivas para usuarios tanto en web como en móvil, aprovechando al máximo la marca o el producto que el cliente dese explotar en su sitio web</p>
                </div>
                <div class="columns" data-aos="fade-up" data-aos-delay="300">
                    <i class="fas fa-laptop"></i>
                    <h3 data-i18n="development">Desarrollo WEB</h3>
                    <p data-i18n="development-info">Creación de páginas web, bien estructuradas, buen diseño responsivo, paleta de colores atractivas, con interacciones que le den al usuario satisfacción cuando navegue por el sitio web.</p>
                </div>
                <div class="columns" data-aos="fade-up" data-aos-delay="400">
                    <i class="fas fa-chart-line"></i>
                    <h3 data-i18n="marketing">Marketing digitals</h3>
                    <p data-i18n="marketing-info">Preparar una estrategia y objetivos para la promoción de la marca que nos proporcione el cliente, utilizando internet u otras plataformas para promover productos y servicios de la marca en cuestión.</p>
                </div>
                <div class="columns" data-aos="fade-up" data-aos-delay="500">
                    <i class="fas fa-wrench"></i>
                    <h3 data-i18n="maintenance">Mantenimiento web</h3>
                    <p data-i18n="maintenance-info">Mantenimiento completo de páginas web para detectar y solucionar errores, actualización de contenido ya sean textos, fotos, elementos de diseño web, añadir nuevas funciones, etc.</p>
                </div>
                <div class="columns" data-aos="fade-up" data-aos-delay="600">
                    <i class="fas fa-search"></i>
                    <h3 data-i18n="seo">Posicionamiento web (SEO)</h3>
                    <p data-i18n="seo-info">Posicionamiento web mediante SEO, así tu pagina web aparezca en los principales resultados de búsqueda acorde a tu negocio, tanto en Google, Bing, u otros buscadores de internet</p>
                </div>
                <div class="columns" data-aos="fade-up" data-aos-delay="700">
                    <i class="fas fa-tachometer-alt"></i>
                    <h3 data-i18n="optimization">Optimización web</h3>
                    <p data-i18n="optimization-info">Optimización completa de tu pagina web, mejorando la velocidad de carga, usando imágenes optimizadas,, un buen URL, para dar una mejor experiencia a los usuarios que visiten el sitio web</p>
                </div>
            </div>
        </section>

        <!-- Pricing Section -->
        <section class="site-services">
            <h2 class="heading" data-i18n="services-price">Precios</h2>
            <div class="row">
                <!-- Essential Card -->
                <div class="columns" data-aos="fade-up" data-aos-delay="200">
                    <h3 data-i18n="services-info-title-1">Esencial</h3>
                    <h4 class="sub-title" data-i18n="services-info-sub-title-1">Perfecto para nuevos negocios</h4>
                    <p class="numero"><span>$</span>150</p>
                    <ul class="ul-cards-services">
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-1-p1">1 página responsiva</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p2">+3 secciones por página</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p3">Formulario de contacto</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p4">Dominio por 1 año</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p5">Hosting por 1 año</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-1-p6">Entregado en 5 días hábiles</span>
                        </li>
                    </ul>
                </div>

                <!-- Professional Card -->
                <div class="columns recomendado" data-aos="fade-up" data-aos-delay="300">
                    <h3 data-i18n="services-info-title-2">Profesional</h3>
                    <h4 class="sub-title" data-i18n="services-info-sub-title-2">Diseñado para medianas empresas</h4>
                    <p class="numero"><span>$</span>400</p>
                    <ul class="ul-cards-services">
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-2-p1">5 páginas responsivas</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p2">+3 secciones por página</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p3">Formulario de contacto</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p4">Dominio por 1 año</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p5">Hosting por 1 año</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p6">animaciones</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p7">Mantenimiento gratuito por 6 meses</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-2-p6">Entregado en 7 días hábiles</span>
                        </li>
                    </ul>
                </div>

                <!-- Premium Card -->
                <div class="columns" data-aos="fade-up" data-aos-delay="400">
                    <h3>Premium</h3>
                    <h4 class="sub-title" data-i18n="services-info-sub-title-3">Ideal para grandes sitios web</h4>
                    <p class="numero"><span>$</span>700</p>
                    <ul class="ul-cards-services">
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-3-p1">+10 páginas responsivas</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p2">+3 secciones por página</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p3">Formulario de contacto</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p4">Dominio por 1 año</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p5">Hosting por 1 año</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-p6">animaciones</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-3-p7">Mantenimiento gratuito por 1 año</span>
                        </li>
                        <li>
                            <i class="fas fa-check"></i>
                            <span data-i18n="services-info-3-p6">Entregado en 14 días hábiles</span>
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- FAQ Accordion Section -->
        <section class="preguntas">
            <h2 class="heading" data-i18n="services-questions">Preguntas Frecuentes</h2>
            <div class="accordion-container">
                <div class="accordion-item" data-aos="fade-right" data-aos-delay="300">
                    <div class="accordion">
                        <div class="accordion-heading">
                            <h3 data-i18n="services-questions-1">¿Qué es una página web responsiva?</h3>
                            <i class="fas fa-angle-down"></i>
                        </div>
                        <p class="accordioin-content" data-i18n="services-questions-p1">Es aquella página capaz de adaptarse a cualquier dispositivo donde se visualice, como celulares, tablets, laptops, sin perder diseño ni usabilidad.</p>
                    </div>
                </div>

                <div class="accordion-item" data-aos="fade-left" data-aos-delay="300">
                    <div class="accordion">
                        <div class="accordion-heading">
                            <h3 data-i18n="services-questions-2">¿Qué es un Dominio y un Hosting?</h3>
                            <i class="fas fa-angle-down"></i>
                        </div>
                        <p class="accordioin-content" data-i18n="services-questions-p2">Ambos son elementos esenciales de un sitio web. En resumen, el dominio es la dirección de la página web, mientras que el hosting proporciona el espacio y recursos necesarios para alojar el sitio.</p>
                    </div>
                </div>

                <div class="accordion-item" data-aos="fade-right" data-aos-delay="300">
                    <div class="accordion">
                        <div class="accordion-heading">
                            <h3 data-i18n="services-questions-3">¿Es necesario un mantenimiento mensual?</h3>
                            <i class="fas fa-angle-down"></i>
                        </div>
                        <p class="accordioin-content" data-i18n="services-questions-p3">Un mantenimiento regular de tu sitio web te permite atraer y retener clientes con nueva información, nuevos productos y servicios, además de ayudarte a mantener o mejorar tu posicionamiento en Google.</p>
                    </div>
                </div>

                <div class="accordion-item" data-aos="fade-left" data-aos-delay="300">
                    <div class="accordion">
                        <div class="accordion-heading">
                            <h3 data-i18n="services-questions-4">Formas de pago</h3>
                            <i class="fas fa-angle-down"></i>
                        </div>
                        <p class="accordioin-content" data-i18n="services-questions-p4">Puedes pagar de forma online mediante tarjetas de crédito o débito, y también realizar pagos mediante transferencias bancarias.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <ScrollToTop />
    
    <Footer />
</Layout>

<script>
    // Accordion Toggle Logic
    document.addEventListener("DOMContentLoaded", () => {
        const accordions = document.querySelectorAll(".accordion");
        accordions.forEach(acc => {
            acc.addEventListener("click", () => {
                const isActive = acc.classList.contains("active");
                
                // Close all other accordions first
                accordions.forEach(item => item.classList.remove("active"));
                
                if (!isActive) {
                    acc.classList.add("active");
                }
            });
        });
    });
</script>