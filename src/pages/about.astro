"---\nimport Layout from '../layouts/Layout.astro';\nimport Header from '../components/Header.astro';\nimport ParticleBackground from '../components/ParticleBackground.astro';\nimport ScrollToTop from '../components/ScrollToTop.astro';\nimport Footer from '../components/Footer.astro';\nimport '../../src/styles/AboutPage.css';\n---\n\n<Layout title=\"Sobre mi =(Nahuel61920)=>\">\n    <Header isHomePage={false} />\n    \n    <ParticleBackground />\n\n    <main>\n        <section class=\"sobre-mi-seccion\" id=\"sobre-mi\">\n            <div class=\"sobre-mi-container\">\n                <div class=\"sobre-mi-img-container\">\n                    <img src=\"/img/home.jpg\" alt=\"Nahuel Carrizo\" class=\"sobre-mi-img\" />\n                    \n                    <a href=\"/cv.pdf\" target=\"_blank\" rel=\"noopener noreferrer\" download=\"cv.pdf\" class=\"btn-codigo cv buttonDownload\" data-i18n=\"btn-cv\">\n                        Descargar CV\n                    </a>\n                </div>\n                <div class=\"sobre-mi-info\">\n                    <p data-i18n=\"about-info-1\">\n                        Hola soy Esteban Nahuel Carrizo, estudiante de la Universidad Tecnológica de Tucumán; Me considero una persona apasionada por la programación y el desarrollo web dado que en 2020 tuve la oportunidad conocer este mundo del front-end y pude crear mi primera página web solo usando HTML y CSS desde allí, sentí una gran pasión por el desarrollo web, ya que puedes hacer cosas impresionante sabiendo cómo usar HTML, CSS, JavaScript y hasta el día de hoy sigo sintiendo esa misma pasión cuando creo una página web.\n                    </p>\n\n                    <div class=\"hide parrafo-active\">\n                        <p data-i18n=\"about-info-2\">\n                            Me considero una persona autodidacta dado que me gusta estar en constante aprendizaje día a día, tanto como de nuevas tecnologías, como de nuevos métodos de desarrollo que me ayuden a pulir y elevar mi nivel de aprendizaje.\
