---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ParticleBackground from '../../components/ParticleBackground.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import Footer from '../../components/Footer.astro';
import '../../../src/styles/ProjectPage.css';
---

<Layout title="Proyectos =(ANONIMO432HZ)=>">
    <Header isHomePage={false} />
    
    <ParticleBackground />

    <main>
        <section class="proyectos mas-proyect" id="proyectos">
            <h1 class="heading" data-i18n="projects">Proyectos</h1>
            <nav class="navbar nav-proj">
                <a href="/project" class="active" data-i18n="site-web">Páginas web</a>
                <a href="/project/app">Apps & Herramientas</a>
            </nav>
        </section>

        <!-- Projects Grid -->
        <section class="projects__grid paginas-web">
            {[8, 5].map((num) => (
                <div class="projects__item">
                    <a href="#" class="project-trigger" data-modal={`modal-${num}`}>
                        <img src={`/img/proyecto-${num}.jpg`} alt="" class="projects__img" />
                    </a>
                </div>
            ))}
        </section>
    </main>

    <!-- Modals -->
    <!-- Modal 8 -->
    <div id="modal-8" class="overlay">
        <div class="contenedor-modal">
            <button class="boton-cerrar">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x" viewBox="0 0 16 16">
                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                </svg>
            </button>
            <div class="content-modal">
                <div class="pw-content">
                    <div class="eins-modal-preview"><img src="/img/proyecto-8-com.png" alt="" /></div>
                    <div class="eins-modal-text">
                        <p data-i18n="projects-info-8-p1">Servicios.pe</p>
                        <p data-i18n="projects-info-8-p2">Es una plataforma web y directorio profesional diseñada para facilitar la búsqueda, publicación y contratación de servicios especializados en todo el Perú.</p>
                        <div class="eins-modal-text-2">
                            <span data-i18n="projects-link">Enlace:</span> <a href="https://servicios-pe.vercel.app" target="_blank">https://servicios-pe.vercel.app</a>
                        </div>
                        <div class="eins-modal-text-2" style="padding: 1rem 0;">
                            <span>Repositorio:</span> <a href="https://github.com/ANONIMO432HZ/Servicios.pe" target="_blank">https://github.com/ANONIMO432HZ/Servicios.pe</a>
                        </div>
                        <div class="eins-modal-text-3">
                            <span data-i18n="projects-tec">Tecnologías Utilizadas:</span>
                            <div class="eins-modal-tec">
                                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg" alt="Astro" />
                                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg" alt="TypeScript" />
                                <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/javascript/javascript-plain.svg" alt="JavaScript" />
                                <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/css3/css3-original.svg" alt="CSS3" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal 5 -->
    <div id="modal-5" class="overlay">
        <div class="contenedor-modal">
            <button class="boton-cerrar">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x" viewBox="0 0 16 16">
                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                </svg>
            </button>
            <div class="content-modal">
                <div class="pw-content">
                    <div class="eins-modal-preview"><img src="/img/proyecto-5-com.png" alt="" /></div>
                    <div class="eins-modal-text">
                        <p data-i18n="projects-info-5-p1">Barbershop Landing</p>
                        <p data-i18n="projects-info-5-p2">Una página de aterrizaje moderna y completamente responsiva diseñada para promocionar servicios, tarifas y reservas de una barbería profesional.</p>
                        <div class="eins-modal-text-2">
                            <span data-i18n="projects-link">Enlace:</span> <a href="https://barbershop-huanta.vercel.app/" target="_blank">https://barbershop-huanta.vercel.app/</a>
                        </div>
                        <div class="eins-modal-text-3">
                            <span data-i18n="projects-tec">Tecnologías Utilizadas:</span>
                            <div class="eins-modal-tec">
                                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg" alt="Astro" />
                                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg" alt="TypeScript" />
                                <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/javascript/javascript-plain.svg" alt="JavaScript" />
                                <img src="https://raw.githubusercontent.com/devicons/devicon/master/icons/css3/css3-original.svg" alt="CSS3" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <ScrollToTop />
    
    <Footer />
</Layout>

<script>
    // Handle modal show/hide
    document.addEventListener("DOMContentLoaded", () => {
        const triggers = document.querySelectorAll(".project-trigger");
        const closeBtns = document.querySelectorAll(".boton-cerrar");
        const overlays = document.querySelectorAll(".overlay");

        triggers.forEach(trigger => {
            trigger.addEventListener("click", (e) => {
                e.preventDefault();
                const modalId = trigger.getAttribute("data-modal");
                if (modalId) {
                    const modal = document.getElementById(modalId);
                    modal?.classList.add("active");
                }
            });
        });

        closeBtns.forEach(btn => {
            btn.addEventListener("click", () => {
                const modal = btn.closest(".overlay");
                modal?.classList.remove("active");
            });
        });

        overlays.forEach(overlay => {
            overlay.addEventListener("click", (e) => {
                if (e.target === overlay) {
                    overlay.classList.remove("active");
                }
            });
        });
    });
</script>