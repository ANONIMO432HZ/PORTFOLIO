---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ParticleBackground from '../../components/ParticleBackground.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import Footer from '../../components/Footer.astro';
import '../../../src/styles/ProjectPage.css';
---

<Layout title="Proyectos Apps & Herramientas =(ANONIMO432HZ)=>">
    <Header isHomePage={false} />
    
    <ParticleBackground />

    <main>
        <section class="proyectos mas-proyect" id="proyectos">
            <h1 class="heading" data-i18n="projects">Proyectos</h1>
            <nav class="navbar nav-proj">
                <a href="/project" data-i18n="site-web">Páginas web</a>
                <a href="/project/app" class="active">Apps & Herramientas</a>
            </nav>
        </section>

        <!-- Projects Grid -->
        <section class="projects__grid apps">
            {[18, 17, 10].map((num) => {
                const extension = num === 10 ? 'jpg' : 'png';
                return (
                    <div class="projects__item">
                        <a href="#" class="project-trigger" data-modal={`modal-app-${num}`}>
                            <img src={`/img/proyecto-app-${num}.${extension}`} alt="" class="projects__img" />
                        </a>
                    </div>
                );
            })}
        </section>
    </main>

    <!-- Modals -->
    <!-- Modal 18 -->
    <div id="modal-app-18" class="overlay">
        <div class="contenedor-modal">
            <button class="boton-cerrar">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x" viewBox="0 0 16 16">
                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                </svg>
            </button>
            <div class="content-modal">
                <div class="pw-content">
                    <div class="eins-modal-preview"><img src="/img/proyecto-app-18-com.png" alt="" /></div>
                    <div class="eins-modal-text">
                        <p>DevSuite</p>
                        <p data-i18n="projectsApp-info-18-p1">DevSuite</p>
                        <p data-i18n="projectsApp-info-18-p2">DevSuite es una suite de más de 17 herramientas útiles orientadas a desarrolladores, informáticos y entusiastas de la tecnología, incluyendo conversores de base numérica, decodificador JWT y utilidades criptográficas.</p>
                        <div class="eins-modal-text-2">
                            <span data-i18n="projects-link">Enlace:</span> <a href="https://dev-suite.vercel.app/" target="_blank">https://dev-suite.vercel.app/</a>
                        </div>
                        <div class="eins-modal-text-3">
                            <span data-i18n="projects-tec">Tecnologías Utilizadas:</span>
                            <div class="eins-modal-tec-2">
                                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/react/react-original.svg" alt="React" />
                                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg" alt="TypeScript" />
                                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tailwindcss/tailwindcss-original.svg" alt="Tailwind CSS" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal 17 -->
    <div id="modal-app-17" class="overlay">
        <div class="contenedor-modal">
            <button class="boton-cerrar">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x" viewBox="0 0 16 16">
                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                </svg>
            </button>
            <div class="content-modal">
                <div class="pw-content">
                    <div class="eins-modal-preview"><img src="/img/proyecto-app-17-com.png" alt="" /></div>
                    <div class="eins-modal-text">
                        <p>ChromiumSpecter</p>
                        <p data-i18n="projectsApp-info-17-p1">ChromiumSpecter</p>
                        <p data-i18n="projectsApp-info-17-p2">ChromiumSpecter es un auditor de credenciales de grado táctico para navegadores Chromium. Cuenta con un motor de sigilo para la evasión de sandboxes, autodestrucción automática del stub para limpieza forense y exfiltración de rastro automatizada vía Telegram y Discord.</p>
                        <div class="eins-modal-text-2">
                            <span>Repositorio:</span> <a href="https://github.com/ANONIMO432HZ/ChromiumSpecter" target="_blank">https://github.com/ANONIMO432HZ/ChromiumSpecter</a>
                        </div>
                        <div class="eins-modal-text-3">
                            <span data-i18n="projects-tec">Tecnologías Utilizadas:</span>
                            <div class="eins-modal-tec">
                                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg" alt="Python" />
                                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bash/bash-original.svg" alt="Shell" />
                                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/windows8/windows8-original.svg" alt="Windows" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal 10 -->
    <div id="modal-app-10" class="overlay">
        <div class="contenedor-modal">
            <button class="boton-cerrar">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x" viewBox="0 0 16 16">
                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                </svg>
            </button>
            <div class="content-modal">
                <div class="pw-content">
                    <div class="eins-modal-preview"><img src="/img/proyecto-app-10.jpg" alt="" /></div>
                    <div class="eins-modal-text">
                        <p data-i18n="projectsApp-info-10-p1">WiFi-SpecterGhost</p>
                        <p data-i18n="projectsApp-info-10-p2">WiFi-SpecterGhost es una herramienta de recuperación de credenciales WiFi guardadas en entornos Windows con un solo click. Permite obtener contraseñas y perfiles de manera rápida.</p>
                        <div class="eins-modal-text-2">
                            <span>Repositorio:</span> <a href="https://github.com/ANONIMO432HZ/WiFi-SpecterGhost" target="_blank">https://github.com/ANONIMO432HZ/WiFi-SpecterGhost</a>
                        </div>
                        <div class="eins-modal-text-3">
                            <span data-i18n="projects-tec">Tecnologías Utilizadas:</span>
                            <div class="eins-modal-tec">
                                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/powershell/powershell-original.svg" alt="PowerShell" />
                                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bash/bash-original.svg" alt="Shell" />
                                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/windows8/windows8-original.svg" alt="Windows" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <ScrollToTop />
    
    <Footer />
</Layout>

<script>
    // Handle modal show/hide
    document.addEventListener("DOMContentLoaded", () => {
        const triggers = document.querySelectorAll(".project-trigger");
        const closeBtns = document.querySelectorAll(".boton-cerrar");
        const overlays = document.querySelectorAll(".overlay");

        triggers.forEach(trigger => {
            trigger.addEventListener("click", (e) => {
                e.preventDefault();
                const modalId = trigger.getAttribute("data-modal");
                if (modalId) {
                    const modal = document.getElementById(modalId);
                    modal?.classList.add("active");
                }
            });
        });

        closeBtns.forEach(btn => {
            btn.addEventListener("click", () => {
                const modal = btn.closest(".overlay");
                modal?.classList.remove("active");
            });
        });

        overlays.forEach(overlay => {
            overlay.addEventListener("click", (e) => {
                if (e.target === overlay) {
                    overlay.classList.remove("active");
                }
            });
        });
    });
</script>